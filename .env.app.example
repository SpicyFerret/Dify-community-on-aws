# =============================================================================
# Variaveis da camada de APP (deploy do Dify Community via docker-compose)
#
# REFERENCIA/DOC: estas vars sao injetadas AUTOMATICAMENTE no .env do Dify pelo
# app/deploy.sh (rodado na EC2 via SSM). Voce NAO precisa preencher nada aqui pro
# pipeline funcionar: o bucket e a regiao sao derivados em runtime e o SECRET_KEY
# e' gerado/persistido na propria instancia. Este arquivo serve so de documentacao.
#
# Lista completa de variaveis do Dify:
# https://docs.dify.ai/en/self-host/configuration/environments
# =============================================================================

# ===== Storage de arquivos em S3 =====
# Usa o bucket criado pela infra (output `s3_bucket_name`). O nome e' deterministico:
# <project>-<environment>-<accountId>-<region>  (ex: dify-prod-<accountId>-<region>).
# Com S3_USE_AWS_MANAGED_IAM=true o Dify usa a IAM role da instancia,
# entao NAO e' necessario S3_ACCESS_KEY / S3_SECRET_KEY.
STORAGE_TYPE=s3
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET_NAME=dify-prod-<accountId>-<region>
S3_USE_AWS_MANAGED_IAM=true
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ===== E-mail (SMTP via Amazon SES) - OPCIONAL =====
# Sem isto, o Dify exibe "Email server is not set up" e os convites de membros
# so saem como link manual. Habilita o envio (ex.: convites) por SMTP do SES.
#
# COMO LIGAR (nada disso vai pro codigo):
#   1. No SES (mesma regiao): verifique a identidade (dominio/e-mail do FROM) e
#      peca "production access" (sair do sandbox) p/ enviar a qualquer destino.
#   2. SES -> SMTP settings -> Create SMTP credentials (gera usuario+senha SMTP,
#      diferentes das access keys da AWS; a senha aparece UMA vez).
#   3. Defina as repository VARIABLES abaixo (Settings -> Variables) e o
#      repository SECRET `SMTP_PASSWORD` (Settings -> Secrets). O workflow publica
#      a senha no SSM Parameter Store (SecureString) e o deploy.sh a injeta aqui.
#
# Repository variables consumidas pelo workflow:
#   MAIL_TYPE=smtp                       (vazio = e-mail desligado)
#   MAIL_DEFAULT_SEND_FROM=Dify <no-reply@seu-dominio>
#   SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=465
#   SMTP_USERNAME=<usuario SMTP do SES>
#   SMTP_USE_TLS=true
#   SMTP_OPPORTUNISTIC_TLS=false         (use true se SMTP_PORT=587)
# Repository secret:
#   SMTP_PASSWORD=<senha SMTP do SES>    (nunca trafega pelo SSM; vai p/ Param Store)
MAIL_TYPE=
MAIL_DEFAULT_SEND_FROM=
SMTP_SERVER=
SMTP_PORT=465
SMTP_USERNAME=
# SMTP_PASSWORD -> via secret/Parameter Store, NAO definir aqui
SMTP_USE_TLS=true
SMTP_OPPORTUNISTIC_TLS=false
