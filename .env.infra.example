# =============================================================================
# Variaveis da camada de INFRA (Terraform + GitHub Actions)
#
# Uso local:
#   cp .env.infra.example .env.infra
#   # preencha os valores
#   set -a && source .env.infra && set +a
#   terraform -chdir=infra init \
#     -backend-config="bucket=$TF_STATE_BUCKET" \
#     -backend-config="key=$TF_STATE_KEY" \
#     -backend-config="region=$AWS_REGION" \
#     -backend-config="dynamodb_table=$TF_STATE_LOCK_TABLE"
#   terraform -chdir=infra plan
#
# No GitHub Actions, cada variavel abaixo deve existir como Secret do repositorio.
# =============================================================================

# ===== AWS (credenciais + regiao) =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===== Backend do Terraform (S3 + DynamoDB) =====
# Bucket e tabela precisam existir ANTES do primeiro init (ver README > Bootstrap).
TF_STATE_BUCKET=dify-tfstate-<conta-id>
TF_STATE_KEY=infra/terraform.tfstate
TF_STATE_LOCK_TABLE=dify-tflock

# ===== Variaveis do Terraform (TF_VAR_*) =====
TF_VAR_project=dify
TF_VAR_environment=prod
TF_VAR_aws_region=us-east-1

# Compute / EC2
TF_VAR_instance_type=t3.medium
TF_VAR_root_volume_size=30
# Chave publica SSH (acesso via WARP). Ex: conteudo de ~/.ssh/id_ed25519.pub
TF_VAR_ssh_public_key="ssh-ed25519 AAAA... user@host"

# Rede
TF_VAR_vpc_cidr=10.20.0.0/16
TF_VAR_subnet_cidr=10.20.1.0/24

# Storage Dify (bucket criado pelo Terraform; nome globalmente unico)
TF_VAR_s3_bucket_name=dify-storage-<conta-id>

# Agendamento (EventBridge Scheduler) - liga 08h / desliga 18h, Seg-Sex
TF_VAR_schedule_timezone=America/Sao_Paulo
TF_VAR_start_cron=cron(0 8 ? * MON-FRI *)
TF_VAR_stop_cron=cron(0 18 ? * MON-FRI *)

# Cloudflare (provider gerencia tunnel + DNS)
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_zone_id=
TF_VAR_app_hostname=dify.example.com
TF_VAR_tunnel_name=dify-tunnel
