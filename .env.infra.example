# =============================================================================
# Variaveis da camada de INFRA (OpenTofu + GitHub Actions)
#
# Uso local:
#   cp .env.infra.example .env.infra
#   # preencha os valores
#   set -a && source .env.infra && set +a
#   ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text)"
#   tofu -chdir=infra init \
#     -backend-config="bucket=dify-tfstate-${ACCOUNT_ID}-${AWS_REGION}" \
#     -backend-config="key=infra/terraform.tfstate" \
#     -backend-config="region=$AWS_REGION" \
#     -backend-config="dynamodb_table=dify-tflock"
#   tofu -chdir=infra plan
#
# No GitHub Actions, cada variavel abaixo deve existir como Secret do repositorio
# (AWS_REGION e' uma repository VARIABLE, nao secret).
# =============================================================================

# ===== AWS (credenciais + regiao) =====
AWS_REGION=us-east-1 # Variable
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ACCOUNT_ID=637423427252 # Secret

# ===== Backend do OpenTofu (S3 + DynamoDB) =====
# CHUMBADO/DETERMINISTICO - nao e' secret. O nome do bucket e' montado como
# dify-tfstate-<accountId>-<region>. No CI vem do env do workflow:
#   STATE_BUCKET_PREFIX=dify-tfstate | STATE_KEY=infra/terraform.tfstate | STATE_LOCK_TABLE=dify-tflock

# ===== Variaveis do Terraform (TF_VAR_*) =====
TF_VAR_project=dify
TF_VAR_environment=prod
TF_VAR_aws_region=us-east-1

# Compute / EC2
TF_VAR_instance_type=t3.medium
TF_VAR_root_volume_size=30
# Chave publica SSH (acesso via WARP). Ex: conteudo de ~/.ssh/id_ed25519.pub
TF_VAR_ssh_public_key="ssh-ed25519 AAAA... user@host"

# Rede
TF_VAR_vpc_cidr=10.20.0.0/16
TF_VAR_subnet_cidr=10.20.1.0/24

# Storage Dify: o bucket e' criado pelo OpenTofu com nome DETERMINISTICO
# (<project>-<environment>-<accountId>-<region>, ex: dify-prod-<accountId>-<region>).
# Nao ha variavel a definir aqui.

# Agendamento (EventBridge Scheduler) - liga 08h / desliga 18h, Seg-Sex
TF_VAR_schedule_timezone=America/Sao_Paulo
TF_VAR_start_cron=cron(0 8 ? * MON-FRI *)
TF_VAR_stop_cron=cron(0 18 ? * MON-FRI *)

# Cloudflare (provider gerencia tunnel + DNS)
TF_VAR_cloudflare_api_token=
TF_VAR_cloudflare_account_id=
TF_VAR_cloudflare_zone_id=
TF_VAR_app_hostname=dify.example.com
TF_VAR_tunnel_name=dify-tunnel
